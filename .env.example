# ─────────────────────────────────────────────────────────────
# HomeProtector · 환경 변수 예시
# 이 파일을 복사해 `.env` 로 만든 뒤 본인 키로 채우세요.  (.env 는 git 에 커밋되지 않습니다)
#
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Kakao Maps JavaScript 키 (웹 빌드 전용, 공개 클라이언트 키)
# 카카오 개발자센터 > 내 애플리케이션 > 앱 키 > JavaScript 키
# 사용 도메인에 http://localhost:56940 를 등록해야 지도가 로드됩니다.
KAKAO_JS_KEY=your_kakao_javascript_key

# Kakao Native 앱 키 (네이티브 SDK 연동 시 사용 — 현재 빌드는 미사용)
KAKAO_NATIVE_KEY=your_kakao_native_key

# 주소 검색 모달(다음/카카오 우편번호 서비스)은 별도 키가 필요 없습니다.
#  - 웹    : web/index.html 의 다음 우편번호 JS SDK 팝업
#  - 모바일: kpostal(InAppWebView) — pubspec 의존성으로 자동 포함
# 선택한 주소의 위경도는 (웹)카카오 지오코더 / (모바일)플랫폼 지오코더로 보강합니다.

# ─────────────────────────────────────────────────────────────
# ⚠️ 기상청 키(KMA_SERVICE_KEY)는 이제 이 클라이언트 .env 에 넣지 않습니다.
#    캘린더 강수량(ASOS)·알림 특보·주간 예보(단기예보)는 모두 백엔드(Ready-Flow)가
#    서버에서 기상청을 호출합니다(웹 CORS·키 노출 회피). 따라서 KMA 키는
#    **백엔드 Vercel 프로젝트(ready-flow-ai)의 환경변수**로만 설정하세요:
#
#      vercel env add KMA_SERVICE_KEY production   # (preview/development 도)
#
#    그 키는 data.go.kr 에서 다음 3개 서비스에 각각 활용신청되어 있어야 합니다:
#      ① 기상청_기상특보 조회서비스        → 알림 탭
#      ② 기상청_지상(ASOS) 일자료 조회서비스 → 캘린더 과거 강수량
#      ③ 기상청_단기예보 조회서비스(VilageFcstInfoService_2.0) → 캘린더 미래 예보
#    미신청 서비스는 해당 기능만 503 안내를 표시하고 나머지는 정상 동작합니다.
# ─────────────────────────────────────────────────────────────

# (선택) 침수/기상 API 베이스 URL 오버라이드.
# 비워 두면 기본값 https://ready-flow-ai.vercel.app 를 사용합니다.
# 코드에서는 --dart-define=FLOOD_API_BASE_URL=... 로 주입합니다.
FLOOD_API_BASE_URL=https://ready-flow-ai.vercel.app
