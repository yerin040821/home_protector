# ─────────────────────────────────────────────────────────────
# HomeProtector · 환경 변수 예시
# 이 파일을 복사해 `.env` 로 만든 뒤 본인 키로 채우세요.  (.env 는 git 에 커밋되지 않습니다)
#
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Kakao Maps JavaScript 키 (웹 빌드 전용, 공개 클라이언트 키)
# 카카오 개발자센터 > 내 애플리케이션 > 앱 키 > JavaScript 키
# 사용 도메인에 http://localhost:56940 를 등록해야 지도가 로드됩니다.
KAKAO_JS_KEY=your_kakao_javascript_key

# Kakao Native 앱 키 (네이티브 SDK 연동 시 사용 — 현재 빌드는 미사용)
KAKAO_NATIVE_KEY=your_kakao_native_key

# 기상청 기상특보 조회서비스 키 (알림 탭의 '실시간 특보'에 사용)
# 공공데이터포털(data.go.kr) > "기상청_기상특보 조회서비스" 활용신청 후 발급되는
# 일반 인증키(Encoding) 값을 그대로 붙여넣으세요. run.sh 가 --dart-define 으로 주입합니다.
# 미설정 시 알림 탭은 '연동 대기' 상태로 표시됩니다(데모 데이터 없음).
# 캘린더의 월간 실측 강수량을 쓰려면 같은 키로 "기상청_지상(ASOS) 일자료 조회서비스"도
# 추가 활용신청해야 합니다(미신청 시 캘린더는 403 안내 표시).
# ⚠️ data.go.kr 은 CORS 미지원 → 모바일(Android/iOS)에서만 동작, 웹은 CORS 프록시 경유.
KMA_SERVICE_KEY=your_data_go_kr_service_key

# (선택) 웹에서 기상청 API 호출용 CORS 프록시.
# 기상청(data.go.kr)은 CORS 미지원이라 웹 브라우저에서는 직접 호출이 차단됩니다.
# 모바일 앱은 직접 호출하므로 프록시가 필요 없습니다(권장: 폰에서 테스트).
# 웹에서도 쓰려면 자체 프록시를 띄우고 그 URL 을 넣으세요. 형식 예: https://my-proxy.workers.dev/?url=
# (공개 프록시 allorigins/corsproxy.io 등은 현재 불안정/유료라 기본값으로 쓰지 않습니다.)
# CORS_PROXY=https://your-proxy.example.com/?url=

# (선택) 침수 예측 API 베이스 URL 오버라이드.
# 비워 두면 기본값 https://ready-flow-ai.vercel.app 를 사용합니다.
# 코드에서는 --dart-define=FLOOD_API_BASE_URL=... 로 주입합니다.
FLOOD_API_BASE_URL=https://ready-flow-ai.vercel.app
